# Secrets Configuration (for reference only)
# Copy this file to secrets.tfvars and fill in actual values
# NEVER commit secrets.tfvars to version control

db_master_username   = "admin"
db_master_password   = "your-secure-password-here"
ssh_access_ip        = "YOUR.PUBLIC.IP.ADDRESS/32"
ec2_key_pair_name    = "my-keypair"
